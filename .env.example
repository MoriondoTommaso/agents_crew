# Hybrid Coding Agency — environment configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Ollama (local models)
# ---------------------------------------------------------------------------
# Base URL for your Ollama instance.
# When running via Docker, this is overridden to host.docker.internal automatically.
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# FreeLLM (frontier model API)
# ---------------------------------------------------------------------------
# OpenAI-compatible endpoint for the planning LLM.
# Default: http://localhost:3001/v1
FREELLM_BASE_URL=http://localhost:3001/v1

# API key for the FreeLLM endpoint.
# Set to "none" if your endpoint does not require authentication.
FREELLMAPI_KEY=none

# ---------------------------------------------------------------------------
# Pipeline settings
# ---------------------------------------------------------------------------
# Hard timeout (seconds) for a single LLM call.
# Tip: set slightly lower than your harness timeout to get a clean 504.
# Default: 600
LLM_TIMEOUT_SEC=600
