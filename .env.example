# ── LLM routing ───────────────────────────────────────────────────────────────
# FreeLLM proxy (frontier models: GPT-4o etc.) running on host
FREELLM_BASE_URL=http://host.docker.internal:3001/v1
FREELLMAPI_KEY=none

# Ollama (local models) running on host
OLLAMA_BASE_URL=http://host.docker.internal:11434

# LiteLLM master key — used as ANTHROPIC_API_KEY by Claude Code
# Can be any string, just needs to match between .env and make claude
LITELLM_MASTER_KEY=sk-local

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=changeme

# ── GitHub (used directly by Claude Code built-in tools) ──────────────────────
GITHUB_TOKEN=ghp_...

# ── Graphiti memory models (all local via Ollama, no API key needed) ──────────
# Lightest embedding model: nomic-embed-text (~274MB)
GRAPHITI_EMBED_MODEL=nomic-embed-text
# Lightest LLM for entity extraction: qwen2.5:1.5b (~1GB)
GRAPHITI_LLM_MODEL=qwen2.5:1.5b
