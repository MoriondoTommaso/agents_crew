# ────────────────────────────────────────────────────────────────────────────
# agents_crew — environment template
# Copy to .env and fill in the required values. Never commit .env.
# ────────────────────────────────────────────────────────────────────────────

# ── LLM endpoint (OpenAI-compatible) ────────────────────────────────────────
# Used by OpenCode on the host AND by the memory container for entity extraction.
# Swap to any provider without restarting Docker.
#
# FreeLLMAPI (default, self-hosted)
OPENAI_BASE_URL=http://localhost:3001/v1
OPENAI_API_KEY=your-freellm-key
#
# OpenRouter
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...
#
# Groq
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_...
#
# Local Ollama only (full privacy)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama

# LLM model used by the memory service for entity extraction (Graphiti)
# Set to a specific model name or leave as "auto" to let the provider decide.
GRAPHITI_LLM_MODEL=auto

# ── Memory service LLM (inside Docker) ──────────────────────────────────────
# The memory container cannot reach localhost:3001 directly — it uses
# host.docker.internal. Set these to the same provider as above.
#
# Graphiti LLM — LiteLLM proxy (bridges gpt-4.1-nano → Ollama)
# Change api_base in litellm-config.yaml to point to a different model.
FREELLM_BASE_URL=http://litellm:4000/v1
FREELLM_API_KEY=ollama

# ── Embeddings — Mode A: Ollama local (default, zero cost) ──────────────────
# Requires: ollama serve  +  ollama pull nomic-embed-text
GRAPHITI_EMBED_PROVIDER=ollama
GRAPHITI_EMBED_MODEL=nomic-embed-text
GRAPHITI_EMBED_DIM=768
# GRAPHITI_EMBED_BASE_URL and GRAPHITI_EMBED_API_KEY are set automatically.

# ── Embeddings — Mode B: cloud endpoint (no Ollama needed) ──────────────────
# Uncomment ONE of the blocks below and comment out Mode A above.
#
# OpenAI
# GRAPHITI_EMBED_PROVIDER=openai
# GRAPHITI_EMBED_BASE_URL=https://api.openai.com/v1
# GRAPHITI_EMBED_API_KEY=sk-...
# GRAPHITI_EMBED_MODEL=text-embedding-3-small
# GRAPHITI_EMBED_DIM=1536
#
# Groq (uses OpenAI-compatible embeddings endpoint)
# GRAPHITI_EMBED_PROVIDER=openai
# GRAPHITI_EMBED_BASE_URL=https://api.groq.com/openai/v1
# GRAPHITI_EMBED_API_KEY=gsk_...
# GRAPHITI_EMBED_MODEL=llama3-groq-70b-8192-tool-use-preview  # check Groq docs
# GRAPHITI_EMBED_DIM=1536
#
# VoyageAI (best retrieval quality, OpenAI-compatible)
# GRAPHITI_EMBED_PROVIDER=openai
# GRAPHITI_EMBED_BASE_URL=https://api.voyageai.com/v1
# GRAPHITI_EMBED_API_KEY=pa-...
# GRAPHITI_EMBED_MODEL=voyage-3-lite
# GRAPHITI_EMBED_DIM=512

# ── Neo4j ────────────────────────────────────────────────────────────────────
# ⚠️  Change NEO4J_PASSWORD before first run.
NEO4J_PASSWORD=changeme
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token with scope: repo
GITHUB_TOKEN=ghp_...

# ── Memory namespace ─────────────────────────────────────────────────────────
# One value per project — keeps memory isolated in the shared Neo4j instance.
# Change this when pointing the agent at a different repository.
GRAPHITI_GROUP_ID=agents

# ── Bootstrap tuning ─────────────────────────────────────────────────────────
# Delay (seconds) between episodes during bootstrap.
# Free-tier LLM providers (~20 req/min): use 35.
# Paid plans / local Ollama: use 0.
BOOTSTRAP_EPISODE_DELAY=35
BOOTSTRAP_TIMEOUT=300
