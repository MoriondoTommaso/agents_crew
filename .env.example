# Hybrid Coding Agency — environment configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Pipeline mode
# ---------------------------------------------------------------------------
# hybrid  (default) — SMLRouter decides per-task: planning → api, coding → local
# api               — all tasks go to the frontier API (Ollama not needed)
# local             — all tasks go to Ollama only (zero API spend, offline-safe)
PIPELINE_MODE=hybrid

# ---------------------------------------------------------------------------
# Ollama (local models)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# Coder model pulled in Ollama (PIPELINE_MODE=hybrid or local)
OLLAMA_CODER_MODEL=qwen2.5-coder:14b

# Router model pulled in Ollama (PIPELINE_MODE=hybrid only)
OLLAMA_ROUTER_MODEL=qwen2.5:1.5b

# ---------------------------------------------------------------------------
# FreeLLM (frontier model API)
# ---------------------------------------------------------------------------
FREELLM_BASE_URL=http://localhost:3001/v1
FREELLMAPI_KEY=none

# ---------------------------------------------------------------------------
# Pipeline settings
# ---------------------------------------------------------------------------
# Hard timeout (seconds) for a single LLM call.
# Set slightly lower than your harness timeout for a clean 504.
LLM_TIMEOUT_SEC=600

# ---------------------------------------------------------------------------
# MCP server — GitHub integration
# ---------------------------------------------------------------------------
# Personal access token with repo scope.
# Required for github_* tools. Leave empty to disable GitHub tools.
GITHUB_TOKEN=

# Default owner and repo (avoids repeating them in every tool call).
# Example: GITHUB_OWNER=MoriondoTommaso  GITHUB_REPO=agents_crew
GITHUB_OWNER=
GITHUB_REPO=
