# ── LLM providers ──────────────────────────────────────────────────────────
# OpenAI (required for Graphiti embeddings + entity extraction)
OPENAI_API_KEY=sk-...

# FreeLLM proxy (frontier models: GPT-4o etc.)
FREELLM_BASE_URL=http://host.docker.internal:3001/v1
FREELLMAPI_KEY=none

# Ollama (local models, host machine)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CODER_MODEL=qwen2.5-coder:14b
OLLAMA_ROUTER_MODEL=qwen2.5:1.5b

# ── Pipeline & timeouts ────────────────────────────────────────────────────
# hybrid | api | local
PIPELINE_MODE=hybrid
# seconds before a pipeline call is aborted (default: 600)
LLM_TIMEOUT_SEC=600

# ── GitHub integration (MCP server) ────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-github-username
GITHUB_REPO=agents_crew

# ── Neo4j (Graphiti backend) ───────────────────────────────────────────────
# Change this before going to production
NEO4J_PASSWORD=changeme

# ── Graphiti models (optional overrides) ──────────────────────────────────
# Embedding model used by Graphiti for semantic search
GRAPHITI_EMBED_MODEL=text-embedding-3-small
# LLM used by Graphiti for entity/relation extraction
GRAPHITI_LLM_MODEL=gpt-4o-mini
