# ── LLM endpoint (interchangeable — swap base URL + key to change provider) ───
#
# Default: FreeLLMAPI self-hosted (http://localhost:3001/v1)
#   Get your unified key from the FreeLLMAPI dashboard after adding provider keys.
#   https://github.com/tashfeenahmed/freellmapi
#
# Drop-in alternatives (zero config changes elsewhere):
#   OpenRouter:  OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   Groq:        OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   Ollama:      OPENAI_BASE_URL=http://localhost:11434/v1  OPENAI_API_KEY=ollama
#   Any OpenAI-compat endpoint works — just change these two lines.
#
OPENAI_BASE_URL=http://localhost:3001/v1
OPENAI_API_KEY=freellmapi-your-unified-key-here


# ── Ollama (local models — used only by the memory service embedder) ───────────
OLLAMA_BASE_URL=http://host.docker.internal:11434


# ── Neo4j ───────────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=changeme


# ── GitHub (used by OpenCode built-in git tools) ────────────────────────────
GITHUB_TOKEN=ghp_...


# ── Graphiti memory service ───────────────────────────────────────────────────
#
# LLM (entity extraction) — defaults to FreeLLMAPI.
# For local-only (no cloud, no rate limits):
#   FREELLM_BASE_URL=http://host.docker.internal:11434/v1
#   FREELLM_API_KEY=ollama
#   GRAPHITI_LLM_MODEL=qwen2.5-coder:14b
#
# For OpenRouter free tier (reliable JSON output):
#   FREELLM_BASE_URL=https://openrouter.ai/api/v1
#   FREELLM_API_KEY=sk-or-v1-...
#   GRAPHITI_LLM_MODEL=google/gemini-2.0-flash-exp:free
#   BOOTSTRAP_EPISODE_DELAY=35
#
FREELLM_BASE_URL=http://host.docker.internal:3001/v1
FREELLM_API_KEY=freellmapi-your-unified-key-here
GRAPHITI_LLM_MODEL=auto
#
# Embedder — always local via Ollama (nomic-embed-text, 768d vectors).
# No API key needed. Run `ollama pull nomic-embed-text` once.
#
GRAPHITI_EMBED_MODEL=nomic-embed-text
GRAPHITI_EMBED_DIM=768
#
# Graph namespace — all episodes and searches are scoped to this group.
# Change per-project if you want isolated memory spaces.
#
GRAPHITI_GROUP_ID=agents
#
# Bootstrap tuning
# BOOTSTRAP_TIMEOUT: seconds to wait for a single episode ingestion (default 600)
# BOOTSTRAP_EPISODE_DELAY: seconds between episodes for free-tier rate limits (default 0)
#
BOOTSTRAP_TIMEOUT=600
BOOTSTRAP_EPISODE_DELAY=0
