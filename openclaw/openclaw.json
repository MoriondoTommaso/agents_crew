{
  "$schema": "https://openclaw.ai/config.schema.json",
  "models": {
    "mode": "merge",
    "providers": {
      "coding-agency": {
        "baseUrl": "http://coding-agency:8000/v1",
        "apiKey": "local",
        "api": "openai-completions",
        "models": [
          {
            "id": "coding-agency",
            "name": "Hybrid Coding Agency (plan + code)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          },
          {
            "id": "coding-plan",
            "name": "Planning only (frontier LLM)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          },
          {
            "id": "coding-code",
            "name": "Code only (local LLM)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    },
    "default": "coding-agency/coding-agency"
  },
  "autoshare": false
}
